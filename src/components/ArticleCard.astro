---
import OptimizedImage from './OptimizedImage.astro';

const { post, href } = Astro.props;
const imageSrc = post.image ?? '/images/placeholder-article.svg';
const imageAlt = post.imageAlt ?? post.title;
---

<a
  href={href}
  class="flex h-full flex-col rounded-[20px] border border-[var(--brand-accent-border)] bg-white p-4 shadow-[0_12px_30px_rgba(79,188,198,0.18)] transition duration-200 hover:-translate-y-1.5 hover:shadow-[0_22px_50px_rgba(79,188,198,0.28)]"
>
  <OptimizedImage
    src={imageSrc}
    alt={imageAlt}
    class="aspect-[3/2] w-full rounded-lg object-cover"
    loading="lazy"
    decoding="async"
  />
  <h3 class="article-card__title mt-4 text-lg font-semibold leading-snug">
    {post.title}
  </h3>
  {post.excerpt ? (
    <p class="article-card__excerpt mt-2 text-sm opacity-80 line-clamp-3">
      {post.excerpt}
    </p>
  ) : (
    <div class="article-card__excerpt mt-2" aria-hidden="true"></div>
  )}
  {post.date ? (
    <p class="mt-auto pt-3 text-xs uppercase tracking-wide text-gray-500">{post.date}</p>
  ) : (
    <div class="mt-auto pt-3" aria-hidden="true"></div>
  )}
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__title {
    min-height: var(--article-title-height, 3.25rem);
  }

  .article-card__excerpt {
    min-height: var(--article-excerpt-height, 3.75rem);
  }
</style>
