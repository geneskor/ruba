---
const { category, href, items = [], compact = false } = Astro.props;
const previewItems = items.slice(0, compact ? 2 : 3);
const hasItems = items.length > 0;
const countLabel = hasItems ? `${items.length} позиций` : 'Нет позиций';
const cardClass = [
  'group relative overflow-hidden border border-[var(--brand-accent-border)] bg-white/90 transition',
  compact
    ? 'rounded-xl p-4 shadow-[0_10px_20px_rgba(15,10,5,0.08)] hover:shadow-[0_16px_28px_rgba(15,10,5,0.14)]'
    : 'rounded-2xl p-5 shadow-[0_14px_30px_rgba(15,10,5,0.08)] hover:-translate-y-1 hover:shadow-[0_20px_44px_rgba(15,10,5,0.16)]'
].join(' ');
const blobClass = 'h-28 w-28 -right-10 -top-10 blur-2xl';
const titleClass = compact
  ? 'text-base font-semibold text-gray-900 transition group-hover:text-[var(--brand-accent)]'
  : 'text-lg font-semibold text-gray-900 transition group-hover:text-[var(--brand-accent)]';
const descClass = compact ? 'mt-2 text-xs text-gray-600' : 'mt-2 text-sm text-gray-600';
const pillClass = compact
  ? 'rounded-full bg-[color:rgba(120,219,226,0.16)] px-2.5 py-0.5 text-[10px] font-semibold text-[var(--brand-accent)]'
  : 'rounded-full bg-[color:rgba(120,219,226,0.16)] px-3 py-1 text-xs font-semibold text-[var(--brand-accent)]';
const chipClass = compact
  ? 'rounded-full border border-[var(--brand-accent-border)] bg-[var(--brand-accent-soft)] px-2.5 py-0.5 text-[10px] font-semibold text-[var(--brand-accent-dark)] transition hover:border-[var(--brand-accent)] hover:bg-[var(--brand-accent-soft-2)]'
  : 'rounded-full border border-[var(--brand-accent-border)] bg-[var(--brand-accent-soft)] px-3 py-1 text-xs font-semibold text-[var(--brand-accent-dark)] transition hover:border-[var(--brand-accent)] hover:bg-[var(--brand-accent-soft-2)]';
const linkClass = compact
  ? 'inline-flex items-center gap-2 text-xs font-semibold text-[var(--brand-accent)] transition group-hover:text-[var(--brand-accent-dark)]'
  : 'inline-flex items-center gap-2 text-sm font-semibold text-[var(--brand-accent)] transition group-hover:text-[var(--brand-accent-dark)]';
---

<div class={cardClass}>
  <a
    href={href}
    class="absolute inset-0 z-0 rounded-[inherit] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--brand-accent)]"
    aria-label={`Перейти в категорию ${category.title}`}
  ></a>
  {compact ? null : (
    <div class={`absolute rounded-full bg-[color:rgba(120,219,226,0.2)] ${blobClass}`}></div>
  )}
  <div class="relative z-10 flex items-start justify-between gap-3 pointer-events-none">
    <div>
      <h3 class={titleClass}>
        {category.title}
      </h3>
      {category.description ? (
        <p class={descClass}>{category.description}</p>
      ) : null}
    </div>
    <span class={pillClass}>{countLabel}</span>
  </div>

  {hasItems ? (
    <div
      class={`${compact ? 'mt-3 flex flex-wrap gap-2' : 'mt-4 flex flex-wrap gap-2'} relative z-10 pointer-events-auto`}
    >
      {previewItems.map((item) => (
        <a class={chipClass} href={`/ryba/${item.category}/${item.slug}/`}>
          {item.name}
        </a>
      ))}
    </div>
  ) : (
    <p class={`${compact ? 'mt-3 text-xs text-gray-500' : 'mt-3 text-sm text-gray-500'} relative z-10 pointer-events-none`}>
      В этой категории пока нет позиций.
    </p>
  )}

  <div class={`${compact ? 'mt-3' : 'mt-5'} relative z-10 pointer-events-none`}>
    <span class={linkClass}>
      В категорию
      <span aria-hidden="true">→</span>
    </span>
  </div>
</div>
