---
type DeliveryItem = {
  title: string;
  value: string;
};

interface Props {
  title?: string;
  items?: DeliveryItem[];
}

const { title = 'Условия доставки', items = [] } = Astro.props as Props;
---

<section class="mt-10 rounded-xl border p-6">
  <h2 class="text-2xl font-semibold">{title}</h2>
  <dl class="mt-4 grid gap-4 sm:grid-cols-2">
    {items.map((item: DeliveryItem) => (
      <div>
        <dt class="text-sm font-medium text-gray-700">{item.title}</dt>
        <dd class="mt-1 text-sm opacity-80">{item.value}</dd>
      </div>
    ))}
  </dl>
</section>
