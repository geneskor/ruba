---
const { title = 'FAQ', items = [], className = '' } = Astro.props;
const sectionClass = className?.trim() ? className : 'mt-10';
---

<section class={sectionClass}>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--brand-accent)]">FAQ</p>
      <h2 class="mt-2 text-2xl font-semibold">{title}</h2>
    </div>
  </div>

  <div class="mt-5 space-y-3">
    {items.map((item) => (
      <details class="faq-item rounded-2xl border border-[var(--brand-accent-border)] bg-white/90 px-5 py-4 shadow-[0_12px_24px_rgba(15,10,5,0.06)] transition hover:-translate-y-0.5 hover:shadow-[0_18px_30px_rgba(15,10,5,0.12)]">
        <summary class="flex cursor-pointer items-center justify-between gap-4 text-base font-semibold text-gray-900">
          <span set:html={item.question}></span>
          <span class="faq-icon grid h-8 w-8 shrink-0 aspect-square place-items-center rounded-full border border-[var(--brand-accent-border)] text-[var(--brand-accent)]">
            +
          </span>
        </summary>
        <div class="faq-content">
          <p class="pt-3 text-sm text-gray-600" set:html={item.answer}></p>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary {
    list-style: none;
  }

  .faq-item[open] {
    background: #f7fcfd;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-icon {
    transition: transform 0.2s ease;
  }

  .faq-item {
    overflow: hidden;
  }

  .faq-item.is-animating {
    transition: height 0.6s ease-in-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item.is-animating {
      transition: none;
    }
  }
</style>
<script is:inline src="/scripts/faq-accordion.js" defer></script>
