---
const { tone = 'light', className = '' } = Astro.props;
const fishColor = tone === 'light' ? 'rgba(255,255,255,0.18)' : 'rgba(79,188,198,0.35)';
const bubbleColor = tone === 'light' ? 'rgba(255,255,255,0.12)' : 'rgba(79,188,198,0.18)';
const bubbleBorder = tone === 'light' ? 'rgba(255,255,255,0.22)' : 'rgba(79,188,198,0.32)';
---

<div class={`pointer-events-none absolute inset-0 ${className}`} aria-hidden="true">
  <svg
    class="absolute -right-8 top-10 h-24 w-24 sm:-right-10 sm:top-12 sm:h-28 sm:w-28 lg:h-32 lg:w-32"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.4"
    stroke-linecap="round"
    stroke-linejoin="round"
    style={`color: ${fishColor};`}
  >
    <path d="M22 7s-5.646 10 -12.308 10c-3.226 .025 -6.194 -1.905 -7.692 -5c1.498 -3.095 4.466 -5.025 7.692 -5c6.662 0 12.308 10 12.308 10" />
  </svg>

  <svg
    class="absolute left-6 bottom-8 h-16 w-16 sm:left-10 sm:bottom-10 sm:h-20 sm:w-20 lg:left-16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.4"
    stroke-linecap="round"
    stroke-linejoin="round"
    style={`color: ${fishColor}; transform: rotate(16deg) scaleX(-1);`}
  >
    <path d="M3 12c3-3 6-4.5 9-4.5S18 9 21 12c-3 3-6 4.5-9 4.5S6 15 3 12Z" />
    <circle cx="12" cy="12" r="1.6" fill="currentColor" />
  </svg>

  <span
    class="absolute right-24 top-12 h-3 w-3 rounded-full border sm:right-32 sm:top-16"
    style={`background: ${bubbleColor}; border-color: ${bubbleBorder};`}
  ></span>
  <span
    class="absolute left-10 top-16 h-2.5 w-2.5 rounded-full border sm:left-16 sm:top-20"
    style={`background: ${bubbleColor}; border-color: ${bubbleBorder};`}
  ></span>
  <span
    class="absolute right-10 bottom-12 h-2 w-2 rounded-full border sm:right-16 sm:bottom-16"
    style={`background: ${bubbleColor}; border-color: ${bubbleBorder};`}
  ></span>
</div>
