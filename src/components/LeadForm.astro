---
import {
  CONTACT_EMAIL,
  CONTACT_MAX_URL,
  CONTACT_PHONE_DISPLAY,
  CONTACT_PHONE_E164,
  CONTACT_TELEGRAM_URL,
  CONTACT_WHATSAPP_URL
} from '../consts/site';

const {
  title = 'Оставить заявку',
  description = 'Заполните форму, и мы свяжемся с вами в ближайшее время.',
  submitLabel = 'Отправить',
  productName = ''
} = Astro.props;

const formAction = `https://formsubmit.co/${CONTACT_EMAIL}`;
const formSource = Astro.url?.pathname ?? '/';
const thankYouPath = '/spasibo/';
const subject = productName
  ? `Заявка с сайта: ${title} (${productName})`
  : `Заявка с сайта: ${title}`;
---

<section class="lead-form relative overflow-hidden rounded-3xl border border-[var(--brand-accent-border)] bg-white/95 p-6 shadow-[0_18px_36px_rgba(15,10,5,0.12)]">


  <div class="relative z-10">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--brand-accent)]">Заявка</p>
        <h2 class="mt-2 text-2xl font-semibold text-gray-900">{title}</h2>
        {description ? <p class="mt-2 text-sm text-gray-600">{description}</p> : null}
        <p class="mt-3 text-sm font-medium text-gray-700">
          Если хотите, можете связаться с нами самостоятельно:
        </p>
        <div class="mt-3 rounded-2xl border border-[var(--brand-accent-border)] bg-[var(--brand-accent-soft)]/60 px-4 py-4">
          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
            <a
              class="messenger-link messenger-link--phone"
              href={`tel:${CONTACT_PHONE_E164}`}
              aria-label={`Позвонить: ${CONTACT_PHONE_DISPLAY}`}
            >
              <span class="messenger-link__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M5 4h4l2.2 5-2.2 1.2c1.7 3.3 4.1 5.7 7.4 7.4l1.2-2.2 5 2.2v4c-9.4 0-17-7.6-17-17Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </span>
              <span class="messenger-link__phone-number">{CONTACT_PHONE_DISPLAY}</span>
            </a>
            <a
              class="messenger-link messenger-link--wa"
              href={CONTACT_WHATSAPP_URL}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Связаться в WhatsApp"
            >
              <span class="messenger-link__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M5 4h4l2.2 5-2.2 1.2c1.7 3.3 4.1 5.7 7.4 7.4l1.2-2.2 5 2.2v4c-9.4 0-17-7.6-17-17Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </span>
              <span>WhatsApp</span>
            </a>
            <a
              class="messenger-link messenger-link--tg"
              href={CONTACT_TELEGRAM_URL}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Связаться в Telegram"
            >
              <span class="messenger-link__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M20.7 4.2 3.8 10.8c-.8.3-.7 1.5.1 1.7l4.4 1.4 1.6 4.8c.2.7 1.1.8 1.5.3l2.6-3.3 4.3 3.1c.6.4 1.4.1 1.6-.6l2.3-12.4c.1-.9-.8-1.7-1.5-1.3Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
              <span>Telegram</span>
            </a>
            <a
              class="messenger-link messenger-link--max"
              href={CONTACT_MAX_URL}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Связаться в MAX"
            >
              <span class="messenger-link__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M5 18V6h3.2L12 12l3.8-6H19v12h-2.8v-7.4L12.8 16h-1.6l-3.4-5.4V18Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
              <span>MAX</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <form class="mt-6 grid gap-4 sm:grid-cols-2" action={formAction} method="post">
      <input type="hidden" name="_subject" value={subject} />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value={thankYouPath} />
      <input type="hidden" name="source" value={formSource} />
      {productName ? <input type="hidden" name="product" value={productName} /> : null}
      <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />
      <label class="grid gap-2 text-sm text-gray-700">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-gray-500">Имя</span>
        <input
          class="rounded-xl border border-[var(--brand-accent-border)] bg-white px-4 py-3 text-sm text-gray-900 shadow-[0_10px_20px_rgba(15,10,5,0.04)] focus:outline-none focus:ring-2 focus:ring-[var(--brand-accent)]/40"
          type="text"
          name="name"
          autocomplete="name"
          placeholder="Иван"
          required
        />
      </label>
      <label class="grid gap-2 text-sm text-gray-700">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-gray-500">Телефон</span>
        <input
          class="rounded-xl border border-[var(--brand-accent-border)] bg-white px-4 py-3 text-sm text-gray-900 shadow-[0_10px_20px_rgba(15,10,5,0.04)] focus:outline-none focus:ring-2 focus:ring-[var(--brand-accent)]/40"
          type="tel"
          name="phone"
          inputmode="tel"
          maxlength="18"
          pattern="^\\+7\\s\\(\\d{3}\\)\\s\\d{3}\\s\\d{2}-\\d{2}$"
          autocomplete="tel"
          placeholder="+7 (000) 000 00-00"
          required
        />
      </label>
      <label class="grid gap-2 text-sm text-gray-700 sm:col-span-2">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-gray-500">Комментарий</span>
        <textarea
          class="min-h-[120px] rounded-xl border border-[var(--brand-accent-border)] bg-white px-4 py-3 text-sm text-gray-900 shadow-[0_10px_20px_rgba(15,10,5,0.04)] focus:outline-none focus:ring-2 focus:ring-[var(--brand-accent)]/40"
          name="comment"
          placeholder="Коротко опишите задачу"
        ></textarea>
      </label>
      <div class="flex flex-wrap items-center justify-between gap-4 sm:col-span-2">
        <p class="text-xs text-gray-300">
          Нажимая кнопку, вы соглашаетесь на <a href="/privacy/" class="underline hover:text-gray-400 transition">обработку персональных данных</a>.
        </p>
        <button
          class="inline-flex items-center justify-center rounded-full bg-[var(--brand-accent)] px-6 py-3 text-sm font-semibold text-white shadow-[0_12px_24px_rgba(79,188,198,0.35)] transition hover:bg-[var(--brand-accent-dark)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand-accent)]/40"
          type="submit"
        >
          {submitLabel}
        </button>
      </div>
    </form>
  </div>
</section>
<style>
  .messenger-link {
    --messenger-start: #0f172a;
    --messenger-end: #1f2937;
    align-items: center;
    background: linear-gradient(135deg, var(--messenger-start), var(--messenger-end));
    border-radius: 999px;
    box-shadow: 0 10px 18px rgba(15, 10, 5, 0.14);
    color: #fff;
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 700;
    gap: 0.5rem;
    justify-content: center;
    letter-spacing: 0.13em;
    min-height: 2.8rem;
    padding: 0.6rem 1rem;
    text-transform: uppercase;
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
  }

  .messenger-link:hover {
    box-shadow: 0 14px 24px rgba(15, 10, 5, 0.2);
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .messenger-link:focus-visible {
    outline: 2px solid rgba(15, 23, 42, 0.45);
    outline-offset: 2px;
  }

  .messenger-link__icon {
    align-items: center;
    background: rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    display: inline-flex;
    height: 1.45rem;
    justify-content: center;
    width: 1.45rem;
  }

  .messenger-link__icon svg {
    height: 0.95rem;
    width: 0.95rem;
  }

  .messenger-link--wa {
    --messenger-start: #25d366;
    --messenger-end: #128c7e;
  }

  .messenger-link--phone {
    --messenger-start: #0ea5b7;
    --messenger-end: #155e75;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .messenger-link__phone-number {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .messenger-link--tg {
    --messenger-start: #38bdf8;
    --messenger-end: #0284c7;
  }

  .messenger-link--max {
    --messenger-start: #0f172a;
    --messenger-end: #334155;
  }
</style>
<script is:inline src="/scripts/lead-form.js" defer></script>
