---
const { src, alt = '', class: className, ...imgAttrs } = Astro.props;
const isRaster = typeof src === 'string' && /\.(png|jpe?g)$/i.test(src);
const baseSrc = isRaster ? src.replace(/\.(png|jpe?g)$/i, '') : src;
const avifSrc = isRaster ? `${baseSrc}.avif` : null;
const webpSrc = isRaster ? `${baseSrc}.webp` : null;
---

{isRaster ? (
  <picture class="block">
    <source srcset={avifSrc} type="image/avif" />
    <source srcset={webpSrc} type="image/webp" />
    <img src={src} alt={alt} class={className} {...imgAttrs} />
  </picture>
) : (
  <img src={src} alt={alt} class={className} {...imgAttrs} />
)}
