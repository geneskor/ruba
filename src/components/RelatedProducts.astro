---
import ProductCard from './ProductCard.astro';

type RelatedProduct = {
  href: string;
  [key: string]: unknown;
};

interface Props {
  title?: string;
  items?: RelatedProduct[];
}

const { title = 'Похожие товары', items = [] } = Astro.props as Props;
---

<section class="mt-10">
  <h2 class="text-2xl font-semibold">{title}</h2>
  <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((item: RelatedProduct) => (
      <ProductCard product={item} href={item.href} />
    ))}
  </div>
</section>
