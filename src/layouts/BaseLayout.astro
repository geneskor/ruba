---
import '../styles/global.css';
import Header from '../components/Header.astro';
import ryba from '../data/catalog/ryba.json';

const { title, description, hero = false, flushBottom = false } = Astro.props;
const mainClass = `px-6 ${flushBottom ? 'pb-0' : 'pb-10'} ${
  hero ? 'pt-0' : 'pt-32 md:pt-36 lg:pt-40'
}`;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Marck+Script&family=Montserrat:wght@500;600;700;800&family=PT+Serif:wght@400;700&display=swap"
    />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-sky-50">
    <Header />
    <slot name="hero" />
    <main class={mainClass}>
      <slot />
    </main>
    <footer class="border-t border-white/10 bg-[#0b1f2a] text-white">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <a class="logo-tagline inline-flex text-xl leading-none text-white" href="/">
              Рыба здесь - есть<span class="logo-excl">!</span>
            </a>
            <p class="mt-3 text-sm text-white/70">
              Рыба для зарыбления: мальки и взрослые особи для дачных прудов, озёр и водоёмов.
            </p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/60">Каталог</p>
            <ul class="mt-4 grid gap-2 text-sm text-white/70">
              {ryba.categories.map((category) => (
                <li>
                  <a class="transition hover:text-white" href={`/ryba/${category.slug}/`}>
                    {category.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/60">Компания</p>
            <ul class="mt-4 grid gap-2 text-sm text-white/70">
              <li>
                <a class="transition hover:text-white" href="/blog/">Блог</a>
              </li>
              <li>
                <a class="transition hover:text-white" href="/contacts/">Контакты</a>
              </li>
            </ul>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/60">Контакты</p>
            <ul class="mt-4 grid gap-2 text-sm text-white/70">
              <li>
                <a
                  class="transition hover:text-white"
                  href="https://maps.google.com/?q=Нахабино+улица+Володарского+3Б"
                  target="_blank"
                  rel="noreferrer"
                >
                  Нахабино, ул. Володарского 3Б
                </a>
              </li>
              <li>
                <a class="transition hover:text-white" href="tel:+79993380337">
                  +7 (999) 338-0-337
                </a>
              </li>
              <li>
                <a class="transition hover:text-white" href="mailto:rybazdesest@mail.ru">
                  rybazdesest@mail.ru
                </a>
              </li>
              <li>Ежедневно 24/7</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="mx-auto max-w-6xl px-6 py-5 text-xs text-white/50"></div>
      </div>
    </footer>
  </body>
</html>
