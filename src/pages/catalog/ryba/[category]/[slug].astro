---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ryba from '../../../../data/catalog/ryba.json';

export async function getStaticPaths() {
  return ryba.products.map((product) => ({
    params: { category: product.category, slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const target = `/ryba/${product.category}/${product.slug}/`;
---

<BaseLayout title="Страница переехала">
  <meta slot="head" name="robots" content="noindex, follow" />
  <meta slot="head" http-equiv="refresh" content={`0; url=${target}`} />
  <h1 class="text-3xl font-bold">Страница переехала</h1>
  <p class="mt-3 text-base opacity-80">
    Новый адрес страницы: <a class="underline" href={target}>{target}</a>.
  </p>
</BaseLayout>
