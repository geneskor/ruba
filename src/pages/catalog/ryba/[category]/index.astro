---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ryba from '../../../../data/catalog/ryba.json';

export async function getStaticPaths() {
  return ryba.categories.map((category) => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const target = `/ryba/${category.slug}/`;
---

<BaseLayout title="Категория переехала">
  <meta slot="head" name="robots" content="noindex, follow" />
  <meta slot="head" http-equiv="refresh" content={`0; url=${target}`} />
  <h1 class="text-3xl font-bold">Категория переехала</h1>
  <p class="mt-3 text-base opacity-80">
    Новый адрес категории: <a class="underline" href={target}>{target}</a>.
  </p>
</BaseLayout>
