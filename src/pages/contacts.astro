---
import BaseLayout from '../layouts/BaseLayout.astro';
import CanonicalLink from '../components/CanonicalLink.astro';
import { CONTACT_EMAIL, CONTACT_PHONE_DISPLAY, CONTACT_PHONE_E164 } from '../consts/site';

const YANDEX_MAP_LAT = 55.859353;
const YANDEX_MAP_LON = 37.182640;
const YANDEX_MAP_POINT = `${YANDEX_MAP_LON},${YANDEX_MAP_LAT}`;
const YANDEX_MAP_MARKER_STYLE = 'pm2blm';
const YANDEX_MAP_LINK = `https://yandex.ru/maps/?ll=${YANDEX_MAP_LON}%2C${YANDEX_MAP_LAT}&z=17&pt=${YANDEX_MAP_POINT},${YANDEX_MAP_MARKER_STYLE}&text=Нахабино%20улица%20Володарского%203Б`;
---

<BaseLayout
  title="Контакты — Рыба для зарыбления пруда | Рыба здесь - есть!"
  description="Контакты для заказа рыбы и консультации по зарыблению пруда: телефон, email, адрес в Нахабино и схема проезда."
  hero
>
  <CanonicalLink slot="head" />
  <section
    slot="hero"
    class="relative overflow-hidden bg-[linear-gradient(135deg,_#0b1f2a_0%,_#123247_55%,_#07131b_100%)] text-white"
  >
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.16),_transparent_55%)]"></div>
    <div class="pointer-events-none absolute -right-16 -top-20 h-64 w-64 rounded-full bg-[color:rgba(79,188,198,0.28)] blur-3xl"></div>
    <div class="relative mx-auto max-w-6xl px-6 pt-32 pb-16 sm:pt-36 sm:pb-20 lg:pt-40">
      <p class="inline-flex items-center gap-2 rounded-full border border-white/30 px-3 py-1 text-xs uppercase tracking-[0.3em] text-white/70">
        Контакты
      </p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-5xl">
        Свяжитесь с нами любым удобным способом
      </h1>
      <p class="mt-4 text-base text-white/80 sm:text-lg">
        Поможем с подбором рыбы и кормов, рассчитаем объём и согласуем доставку.
      </p>
    </div>
  </section>

  <div class="contacts-page text-[var(--color-text)]">

    <div class="bg-[var(--color-bg)] px-6">
      <section class="mx-auto max-w-6xl py-12 sm:py-14">
        <div class="cards-grid grid gap-6 lg:grid-cols-3">
          <a
            class="contact-card focus-ring block border border-[var(--brand-accent-border)] bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-[0_22px_46px_rgba(15,10,5,0.16)]"
            href={YANDEX_MAP_LINK}
            target="_blank"
            rel="noreferrer"
            aria-label="Нахабино, улица Володарского д.3Б"
          >
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-full text-[var(--color-primary)]" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                <path
                  d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"
                  stroke="currentColor"
                  stroke-width="1.6"
                  fill="none"
                />
                <circle cx="12" cy="10" r="2.6" stroke="currentColor" stroke-width="1.6" fill="none" />
              </svg>
            </div>
            <h2 class="mt-4 text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-muted)]">
              АДРЕС
            </h2>
            <p class="mt-3 text-lg font-semibold text-[var(--color-primary)] transition hover:text-[var(--color-primary-dark)]">
              Нахабино, улица Володарского д.3Б
            </p>
          </a>

          <a
            class="contact-card focus-ring block border border-[var(--brand-accent-border)] bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-[0_22px_46px_rgba(15,10,5,0.16)]"
            href={`tel:${CONTACT_PHONE_E164}`}
            aria-label={CONTACT_PHONE_DISPLAY}
          >
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-full text-[var(--color-primary)]" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                <path
                  d="M5 4h4l2.2 5-2.2 1.2c1.7 3.3 4.1 5.7 7.4 7.4l1.2-2.2 5 2.2v4c-9.4 0-17-7.6-17-17Z"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </div>
            <h2 class="mt-4 text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-muted)]">
              ТЕЛЕФОН
            </h2>
            <p class="mt-3 text-lg font-semibold text-[var(--color-primary)] transition hover:text-[var(--color-primary-dark)]">
              {CONTACT_PHONE_DISPLAY}
            </p>
          </a>

          <a
            class="contact-card focus-ring block border border-[var(--brand-accent-border)] bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-[0_22px_46px_rgba(15,10,5,0.16)]"
            href={`mailto:${CONTACT_EMAIL}`}
            aria-label={CONTACT_EMAIL}
          >
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-full text-[var(--color-primary)]" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                <rect
                  x="3"
                  y="6"
                  width="18"
                  height="12"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.6"
                  fill="none"
                />
                <path
                  d="M3.5 7.2 12 13l8.5-5.8"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  fill="none"
                />
              </svg>
            </div>
            <h2 class="mt-4 text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-muted)]">
              EMAIL
            </h2>
            <p class="mt-3 text-lg font-semibold text-[var(--color-primary)] transition hover:text-[var(--color-primary-dark)]">
              {CONTACT_EMAIL}
            </p>
          </a>
        </div>
      </section>

      <section class="mx-auto max-w-6xl pb-12">
        <div class="schedule-card border border-[var(--brand-accent-border)] bg-white/90 px-6 py-8 text-center">
          <h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-muted)]">
            ГРАФИК РАБОТЫ
          </h2>
          <p class="mt-3 text-2xl font-semibold text-[var(--color-primary)]">Ежедневно 24/7</p>
        </div>
      </section>

      <section class="mx-auto max-w-6xl pb-16">
        <div class="map-card border border-[var(--brand-accent-border)] bg-white/90">
          <div
            id="contacts-map"
            class="map-frame focus-ring"
            role="region"
            tabindex="0"
            aria-label="Карта: Нахабино, улица Володарского д.3Б"
            data-lat={String(YANDEX_MAP_LAT)}
            data-lon={String(YANDEX_MAP_LON)}
            data-link={YANDEX_MAP_LINK}
          ></div>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    (() => {
      const mapElement = document.getElementById('contacts-map');
      if (!mapElement) return;

      const lat = Number(mapElement.dataset.lat);
      const lon = Number(mapElement.dataset.lon);
      const mapLink = mapElement.dataset.link ?? 'https://yandex.ru/maps/';
      const center = [lat, lon];

      const renderFallback = () => {
        mapElement.classList.add('map-frame--fallback');
        mapElement.innerHTML = `
          <a class="map-open-link" href="${mapLink}" target="_blank" rel="noreferrer">
            Открыть карту в Яндекс Картах
          </a>
        `;
      };

      const initMap = () => {
        if (!window.ymaps || typeof window.ymaps.ready !== 'function') {
          renderFallback();
          return;
        }

        window.ymaps.ready(() => {
          try {
            const map = new window.ymaps.Map(
              'contacts-map',
              {
                center,
                zoom: 17,
                controls: ['zoomControl'],
              },
              { suppressMapOpenBlock: true },
            );

            const fishPlacemark = new window.ymaps.Placemark(
              center,
              {
                balloonContentHeader: 'Рыба в пруд',
                balloonContentBody: 'Нахабино, улица Володарского д.3Б',
              },
              {
                iconLayout: 'default#image',
                iconImageHref: '/fish.svg',
                iconImageSize: [54, 54],
                iconImageOffset: [-27, -27],
                hideIconOnBalloonOpen: false,
              },
            );

            map.geoObjects.add(fishPlacemark);
            map.behaviors.disable('scrollZoom');
          } catch (_error) {
            renderFallback();
          }
        });
      };

      if (window.ymaps) {
        initMap();
        return;
      }

      const existingScript = document.querySelector('script[data-yandex-maps="v2"]');
      if (existingScript) {
        existingScript.addEventListener('load', initMap, { once: true });
        existingScript.addEventListener('error', renderFallback, { once: true });
        return;
      }

      const script = document.createElement('script');
      script.src = 'https://api-maps.yandex.ru/2.1/?lang=ru_RU';
      script.async = true;
      script.dataset.yandexMaps = 'v2';
      script.addEventListener('load', initMap, { once: true });
      script.addEventListener('error', renderFallback, { once: true });
      document.head.appendChild(script);
    })();
  </script>

  <style>
    .contacts-page {
      --color-primary: var(--brand-accent);
      --color-primary-dark: var(--brand-accent-dark);
      --color-bg: #f0fbfc;
      --color-text: #1b1b1b;
      --color-muted: #6b7280;
      --radius: 24px;
      --shadow: 0 16px 32px rgba(15, 10, 5, 0.08);
    }

    .contact-card,
    .schedule-card,
    .map-card {
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .map-frame {
      width: 100%;
      min-height: 360px;
      border: 0;
      display: block;
    }

    .map-frame--fallback {
      display: grid;
      place-items: center;
      background: linear-gradient(140deg, #eaf6f8, #f7fcfc);
      padding: 24px;
    }

    .map-open-link {
      border-radius: 999px;
      border: 1px solid var(--brand-accent-border);
      background: white;
      color: var(--color-primary);
      font-weight: 600;
      padding: 12px 18px;
      text-decoration: none;
      transition: transform 180ms ease, box-shadow 180ms ease;
      box-shadow: 0 8px 18px rgba(11, 31, 42, 0.08);
    }

    .map-open-link:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(11, 31, 42, 0.12);
    }

    .focus-ring:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 4px;
      border-radius: 8px;
    }

    @media (min-width: 1024px) {
      .cards-grid {
        position: relative;
      }

      .cards-grid::before,
      .cards-grid::after {
        content: '';
        position: absolute;
        top: 16px;
        bottom: 16px;
        width: 1px;
        background: var(--color-primary);
        opacity: 0.22;
      }

      .cards-grid::before {
        left: calc(33.333% - 0.5px);
      }

      .cards-grid::after {
        left: calc(66.666% - 0.5px);
      }
    }
  </style>
</BaseLayout>
