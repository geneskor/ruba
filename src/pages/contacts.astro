---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Контакты">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold">Контакты</h1>
    <p class="mt-4 text-lg opacity-80">
      Укажите актуальные способы связи и время ответа. Этот раздел лучше держать
      максимально точным.
    </p>
    <div class="mt-6 space-y-3">
      <p>Телефон: +7 (000) 000-00-00</p>
      <p>Email: info@example.com</p>
      <p>Адрес: г. Город, ул. Примерная, 1</p>
      <p>График: Пн–Пт, 09:00–18:00</p>
    </div>
  </div>
</BaseLayout>
