---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import categories from '../../../data/categories.json';
import fish from '../../../data/fish.json';

export async function getStaticPaths() {
  return fish.map((item) => ({
    params: { category: item.category, slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const category = categories.find((entry) => entry.slug === item.category);
const categoryTitle = category ? category.title : item.category;
---

<BaseLayout title={item.name} description={item.desc}>
  <div class="max-w-3xl">
    <a class="text-sm underline" href={`/ryba/${item.category}/`}>
      {categoryTitle}
    </a>
    <h1 class="mt-3 text-3xl font-bold">{item.name}</h1>
    <p class="mt-3 text-base opacity-80">{item.desc}</p>
    <p class="mt-4 text-lg font-semibold">{item.priceFrom}</p>
    <div class="mt-6 flex flex-wrap gap-3 text-sm">
      <a class="underline" href="/ryba/">Все рыбы</a>
      <a class="underline" href="/contacts/">Контакты</a>
    </div>
  </div>
</BaseLayout>
