---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import categories from '../../../data/categories.json';
import fish from '../../../data/fish.json';

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const items = fish.filter((item) => item.category === category.slug);
---

<BaseLayout title={`Каталог: ${category.title}`}>
  <div class="max-w-5xl">
    <a class="text-sm underline" href="/ryba/">Все рыбы</a>
    <h1 class="mt-3 text-3xl font-bold">{category.title}</h1>
    <p class="mt-3 text-base opacity-80">
      Подборка видов из категории «{category.title}».
    </p>
  </div>

  {items.length ? (
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <a
          href={`/ryba/${item.category}/${item.slug}/`}
          class="block rounded-xl border p-4 hover:shadow-sm"
        >
          <h2 class="text-xl font-semibold">{item.name}</h2>
          <p class="mt-2 opacity-80">{item.desc}</p>
          <p class="mt-3 font-medium">{item.priceFrom}</p>
        </a>
      ))}
    </div>
  ) : (
    <p class="mt-6 text-sm opacity-70">В этой категории пока нет позиций.</p>
  )}
</BaseLayout>
