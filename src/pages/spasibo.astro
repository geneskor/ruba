---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Спасибо"
  description="Заявка отправлена. Мы свяжемся с вами в ближайшее время."
  hero
>
  <meta slot="head" name="robots" content="noindex, follow" />
  <section
    slot="hero"
    class="relative overflow-hidden bg-[linear-gradient(135deg,_#0b1f2a_0%,_#123247_55%,_#07131b_100%)] text-white"
  >
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.16),_transparent_55%)]"></div>
    <div class="pointer-events-none absolute -right-16 -top-20 h-64 w-64 rounded-full bg-[color:rgba(79,188,198,0.28)] blur-3xl"></div>
    <div class="relative mx-auto max-w-6xl px-6 pt-32 pb-16 sm:pt-36 sm:pb-20 lg:pt-40">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/70">Заявка отправлена</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight sm:text-5xl">
        Спасибо! Мы уже получили ваш запрос.
      </h1>
      <p class="mt-4 max-w-2xl text-base text-white/80 sm:text-lg">
        Мы свяжемся с вами в ближайшее время, чтобы уточнить детали и подтвердить наличие.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 pt-10 pb-12 sm:pt-12">
    <div class="rounded-3xl border border-[var(--brand-accent-border)] bg-white/95 p-8 text-gray-900 shadow-[0_18px_36px_rgba(15,10,5,0.12)]">
      <h2 class="text-2xl font-semibold">Что дальше</h2>
      <p class="mt-3 text-sm text-gray-600">
        Если у вас есть срочный вопрос, свяжитесь с нами напрямую — мы на связи ежедневно 24/7.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded-full bg-[var(--brand-accent)] px-6 py-3 text-sm font-semibold text-white shadow-[0_12px_24px_rgba(79,188,198,0.35)] transition hover:bg-[var(--brand-accent-dark)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand-accent)]/40"
          href="/ryba/"
        >
          Перейти в каталог
        </a>
        <a
          class="inline-flex items-center justify-center rounded-full border border-[var(--brand-accent-border)] px-6 py-3 text-sm font-semibold text-[var(--brand-accent-dark)] transition hover:border-[var(--brand-accent)] hover:bg-[var(--brand-accent-soft)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand-accent)]/30"
          href="/contacts/"
        >
          Контакты
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
